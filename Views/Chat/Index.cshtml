@{
    ViewData["Title"] = "Local Health Buddy";
    Layout = null; @* No shared layout — this is a standalone full-page chat UI *@
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Local Health Buddy</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Nunito:wght@700;800&display=swap" rel="stylesheet" />
    <style>
        /* =============================================
           RESET & BASE
        ============================================= */
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: #e8f4f4;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 16px;
        }

        /* =============================================
           MAIN CHAT CARD
        ============================================= */
        .chat-card {
            width: 100%;
            max-width: 680px;
            height: 88vh;
            max-height: 820px;
            background: #ffffff;
            border-radius: 20px;
            box-shadow: 0 8px 40px rgba(1, 105, 111, 0.15);
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        /* =============================================
           HEADER
        ============================================= */
        .chat-header {
            background: linear-gradient(135deg, #01696f 0%, #019a9e 100%);
            padding: 18px 24px;
            display: flex;
            align-items: center;
            gap: 14px;
            flex-shrink: 0;
        }

        .header-icon {
            width: 46px;
            height: 46px;
            background: rgba(255,255,255,0.2);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 22px;
            flex-shrink: 0;
        }

        .header-text h1 {
            font-family: 'Nunito', sans-serif;
            font-size: 1.15rem;
            font-weight: 800;
            color: #ffffff;
            letter-spacing: 0.3px;
        }

        .header-text p {
            font-size: 0.75rem;
            color: rgba(255,255,255,0.80);
            margin-top: 2px;
        }

        .header-status {
            margin-left: auto;
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 0.72rem;
            color: rgba(255,255,255,0.85);
        }

        .status-dot {
            width: 8px;
            height: 8px;
            background: #7fffb0;
            border-radius: 50%;
            animation: pulse 2s infinite;
        }

        @@keyframes pulse {
            0%, 100% { opacity: 1; }
            50%       { opacity: 0.4; }
        }

        /* =============================================
           DISCLAIMER BANNER
        ============================================= */
        .disclaimer {
            background: #fff8e1;
            border-bottom: 1px solid #ffe082;
            padding: 8px 20px;
            font-size: 0.72rem;
            color: #795548;
            text-align: center;
            flex-shrink: 0;
        }

        /* =============================================
           CHAT MESSAGES AREA
        ============================================= */
        .chat-messages {
            flex: 1;
            overflow-y: auto;
            padding: 20px 20px 10px;
            display: flex;
            flex-direction: column;
            gap: 12px;
            background: #f7fbfb;
        }

        /* Scrollbar styling */
        .chat-messages::-webkit-scrollbar { width: 5px; }
        .chat-messages::-webkit-scrollbar-track { background: transparent; }
        .chat-messages::-webkit-scrollbar-thumb { background: #b2d8d8; border-radius: 4px; }

        /* =============================================
           MESSAGE BUBBLES
        ============================================= */
        .message-row {
            display: flex;
            align-items: flex-end;
            gap: 8px;
            max-width: 82%;
            animation: fadeUp 0.25s ease;
        }

        @@keyframes fadeUp {
            from { opacity: 0; transform: translateY(10px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        /* BOT message row — aligned left */
        .message-row.bot {
            align-self: flex-start;
        }

        /* USER message row — aligned right, reversed */
        .message-row.user {
            align-self: flex-end;
            flex-direction: row-reverse;
        }

        /* Avatar circle for bot */
        .avatar {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: #01696f;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 15px;
            flex-shrink: 0;
        }

        /* Bubble base styles */
        .bubble {
            padding: 10px 15px;
            border-radius: 18px;
            font-size: 0.875rem;
            line-height: 1.55;
            white-space: pre-wrap;    /* Preserves \n line breaks from webhook */
            word-break: break-word;
        }

        /* BOT bubble — white with teal left border */
        .message-row.bot .bubble {
            background: #ffffff;
            color: #1a2e2f;
            border: 1px solid #c8e6e6;
            border-bottom-left-radius: 4px;
            box-shadow: 0 2px 6px rgba(1,105,111,0.07);
        }

        /* USER bubble — teal */
        .message-row.user .bubble {
            background: #01696f;
            color: #ffffff;
            border-bottom-right-radius: 4px;
        }

        /* Timestamp label */
        .timestamp {
            font-size: 0.65rem;
            color: #9ab8b8;
            text-align: center;
            margin: 4px 0;
        }

        /* =============================================
           TYPING INDICATOR (three bouncing dots)
        ============================================= */
        .typing-row {
            display: flex;
            align-items: flex-end;
            gap: 8px;
            align-self: flex-start;
            animation: fadeUp 0.2s ease;
        }

        .typing-bubble {
            background: #ffffff;
            border: 1px solid #c8e6e6;
            border-radius: 18px;
            border-bottom-left-radius: 4px;
            padding: 12px 16px;
            display: flex;
            gap: 5px;
            align-items: center;
        }

        .typing-bubble span {
            width: 7px;
            height: 7px;
            background: #01696f;
            border-radius: 50%;
            animation: bounce 1.2s infinite;
        }
        .typing-bubble span:nth-child(2) { animation-delay: 0.2s; }
        .typing-bubble span:nth-child(3) { animation-delay: 0.4s; }

        @@keyframes bounce {
            0%, 80%, 100% { transform: translateY(0); opacity: 0.4; }
            40%            { transform: translateY(-6px); opacity: 1; }
        }

        /* =============================================
           QUICK SUGGESTION CHIPS
        ============================================= */
        .suggestions {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            padding: 8px 20px 4px;
            background: #f7fbfb;
            flex-shrink: 0;
        }

        .chip {
            background: #e0f3f3;
            color: #01696f;
            border: 1px solid #b2d8d8;
            border-radius: 20px;
            padding: 5px 12px;
            font-size: 0.75rem;
            font-weight: 500;
            cursor: pointer;
            transition: background 0.15s, transform 0.1s;
            white-space: nowrap;
        }

        .chip:hover {
            background: #01696f;
            color: #ffffff;
            transform: translateY(-1px);
        }

        /* =============================================
           INPUT AREA
        ============================================= */
        .chat-input-area {
            padding: 12px 16px 14px;
            background: #ffffff;
            border-top: 1px solid #e0edf0;
            display: flex;
            align-items: center;
            gap: 10px;
            flex-shrink: 0;
        }

        #userInput {
            flex: 1;
            padding: 11px 16px;
            border: 1.5px solid #b2d8d8;
            border-radius: 24px;
            font-size: 0.875rem;
            font-family: 'Inter', sans-serif;
            outline: none;
            color: #1a2e2f;
            background: #f7fbfb;
            transition: border-color 0.2s;
            resize: none;
        }

        #userInput:focus {
            border-color: #01696f;
            background: #ffffff;
        }

        #userInput::placeholder {
            color: #9ab8b8;
        }

        #sendBtn {
            width: 44px;
            height: 44px;
            border-radius: 50%;
            background: #01696f;
            border: none;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            transition: background 0.15s, transform 0.1s;
        }

        #sendBtn:hover  { background: #015558; transform: scale(1.06); }
        #sendBtn:active { transform: scale(0.96); }
        #sendBtn:disabled { background: #b2d8d8; cursor: not-allowed; transform: none; }

        #sendBtn svg { pointer-events: none; }

        /* =============================================
           FOOTER NOTE
        ============================================= */
        .chat-footer-note {
            text-align: center;
            font-size: 0.66rem;
            color: #9ab8b8;
            padding: 6px 16px 8px;
            background: #ffffff;
        }
    </style>
</head>
<body>

<div class="chat-card">

    <!-- ── HEADER ── -->
    <div class="chat-header">
        <div class="header-icon">🩺</div>
        <div class="header-text">
            <h1>Local Health Buddy</h1>
            <p>AI-powered symptom assistant</p>
        </div>
        <div class="header-status">
            <div class="status-dot"></div>
            Online
        </div>
    </div>

    <!-- ── DISCLAIMER ── -->
    <div class="disclaimer">
        ⚠️ This is an AI assistant. It does not replace professional medical advice. Always consult a doctor for serious symptoms.
    </div>

    <!-- ── MESSAGES ── -->
    <div class="chat-messages" id="chatMessages">
        <!-- The welcome message appears here on page load (added by JS below) -->
    </div>

    <!-- ── QUICK CHIPS ── -->
    <div class="suggestions" id="suggestions">
        <button class="chip" onclick="sendChip(this)">How can you help me?</button>
        <button class="chip" onclick="sendChip(this)">What is my diagnosis?</button>
        <button class="chip" onclick="sendChip(this)">Give me a medical report</button>
        <button class="chip" onclick="sendChip(this)">Should I visit a doctor?</button>
    </div>

    <!-- ── INPUT BAR ── -->
    <div class="chat-input-area">
        <input type="text"
               id="userInput"
               placeholder="Describe your symptoms or ask a question…"
               autocomplete="off"
               maxlength="300" />
        <button id="sendBtn" title="Send message" onclick="sendMessage()">
            <!-- Paper-plane icon (inline SVG, no external dependency) -->
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="22" y1="2" x2="11" y2="13"></line>
                <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
            </svg>
        </button>
    </div>

    <div class="chat-footer-note">Local Health Buddy — ABRA_ka_DABRA project • For educational use only</div>

</div>

<script>
    // ─────────────────────────────────────────────
    // SESSION ID: Unique per browser tab/session
    // This keeps each user's Dialogflow conversation separate
    // ─────────────────────────────────────────────
    const sessionId = 'session-' + Date.now() + '-' + Math.random().toString(36).slice(2, 8);

    const messagesContainer = document.getElementById('chatMessages');
    const userInput         = document.getElementById('userInput');
    const sendBtn           = document.getElementById('sendBtn');

    // ─────────────────────────────────────────────
    // WELCOME MESSAGE — shown on page load
    // ─────────────────────────────────────────────
    window.addEventListener('DOMContentLoaded', () => {
        appendBotMessage("Hi! 👋 I'm your Local Health Buddy.\n\nI can help you understand your symptoms and suggest when to visit a doctor.\n\nDescribe what you're feeling to get started!");
        addTimestamp();
    });

    // ─────────────────────────────────────────────
    // ENTER KEY → send message
    // ─────────────────────────────────────────────
    userInput.addEventListener('keydown', function (e) {
        if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            sendMessage();
        }
    });

    // ─────────────────────────────────────────────
    // SEND MESSAGE (main function)
    // ─────────────────────────────────────────────
    async function sendMessage() {
        const text = userInput.value.trim();
        if (!text) return;

        // 1. Show user's message on screen
        appendUserMessage(text);
        userInput.value = '';
        sendBtn.disabled = true;

        // 2. Show the "..." typing indicator while waiting for bot
        const typingId = showTypingIndicator();

        try {
            // 3. Call our C# controller endpoint
            const response = await fetch('/Chat/SendMessage', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: new URLSearchParams({ userMessage: text, sessionId: sessionId })
            });

            const data = await response.json();

            // 4. Remove the typing indicator
            removeTypingIndicator(typingId);

            // 5. Show the bot's reply
            if (data.success && data.reply) {
                appendBotMessage(data.reply);
            } else {
                appendBotMessage("Hmm, I didn't get a response. Please try again.");
            }

        } catch (error) {
            // Network or server error
            removeTypingIndicator(typingId);
            appendBotMessage("⚠️ Could not reach the server. Please check your connection.");
            console.error('Fetch error:', error);
        }

        sendBtn.disabled = false;
        scrollToBottom();
    }

    // ─────────────────────────────────────────────
    // CHIP CLICK (quick suggestion buttons)
    // ─────────────────────────────────────────────
    function sendChip(btn) {
        userInput.value = btn.textContent;
        sendMessage();
    }

    // ─────────────────────────────────────────────
    // HELPER: Append a USER message bubble
    // ─────────────────────────────────────────────
    function appendUserMessage(text) {
        const row = document.createElement('div');
        row.className = 'message-row user';
        row.innerHTML = `<div class="bubble">${escapeHtml(text)}</div>`;
        messagesContainer.appendChild(row);
        scrollToBottom();
    }

    // ─────────────────────────────────────────────
    // HELPER: Append a BOT message bubble
    // ─────────────────────────────────────────────
    function appendBotMessage(text) {
        const row = document.createElement('div');
        row.className = 'message-row bot';
        row.innerHTML = `
            <div class="avatar">🩺</div>
            <div class="bubble">${escapeHtml(text)}</div>`;
        messagesContainer.appendChild(row);
        scrollToBottom();
    }

    // ─────────────────────────────────────────────
    // HELPER: Show three-dot typing indicator
    // Returns an ID so we can remove it later
    // ─────────────────────────────────────────────
    function showTypingIndicator() {
        const id = 'typing-' + Date.now();
        const row = document.createElement('div');
        row.className = 'typing-row';
        row.id = id;
        row.innerHTML = `
            <div class="avatar">🩺</div>
            <div class="typing-bubble">
                <span></span><span></span><span></span>
            </div>`;
        messagesContainer.appendChild(row);
        scrollToBottom();
        return id;
    }

    function removeTypingIndicator(id) {
        const el = document.getElementById(id);
        if (el) el.remove();
    }

    // ─────────────────────────────────────────────
    // HELPER: Add a small timestamp divider
    // ─────────────────────────────────────────────
    function addTimestamp() {
        const div = document.createElement('div');
        div.className = 'timestamp';
        div.textContent = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
        messagesContainer.appendChild(div);
    }

    // ─────────────────────────────────────────────
    // HELPER: Scroll chat to latest message
    // ─────────────────────────────────────────────
    function scrollToBottom() {
        messagesContainer.scrollTop = messagesContainer.scrollHeight;
    }

    // ─────────────────────────────────────────────
    // HELPER: Escape HTML to prevent XSS injection
    // ─────────────────────────────────────────────
    function escapeHtml(text) {
        return text
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/\n/g, '<br>');  // Convert \n newlines to <br> for display
    }
</script>

</body>
</html>
